{
  "expo": {
    "name": "SPARKFIT",
    "slug": "sparkfit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sparkfit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FFF9F9"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sparkfit.app",
      "infoPlist": {
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.sparkfit.app",
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "nothing",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "SPARKFIT 需要相機權限以拍攝身材照片"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "SPARKFIT 需要相簿權限以儲存照片",
          "savePhotosPermission": "SPARKFIT 需要儲存照片到相簿"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SPARKFIT 需要相簿存取權限以選取照片"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "904fed29-262a-4e5a-967a-5354aa306fa9"
      }
    },
    "owner": "mimichild",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/904fed29-262a-4e5a-967a-5354aa306fa9"
    }
  }
}
